# Copy to .env and fill in. Used for local runs (export them into your shell).
# In GitHub Actions these come from repo Secrets/Variables instead (see README).

# --- Email (Brevo) ---
BREVO_API_KEY=
MAIL_TO=vhung@attelascap.com
MAIL_SENDER_EMAIL=vhung@attelascap.com      # must be a verified sender/domain in Brevo
MAIL_SENDER_NAME=PE Multiples Monitor
SEND_WHEN_EMPTY=true                          # email a daily "all clear" even with no alerts

# --- Charts ---
# url     -> reference charts by absolute URL (works in Gmail/Workspace; needs hosting)
# datauri -> embed charts as base64 (self-contained; great for local preview)
CHART_MODE=datauri
# Override the chart URL base (otherwise derived from GITHUB_REPOSITORY/REF in CI)
# CHART_BASE_URL=https://raw.githubusercontent.com/vhung-1/multagent/main/charts

# --- Single-name thresholds (vs own P/E history) ---
SINGLE_LOOKBACK_DAYS=756     # trailing window for mean/sigma (~3y); falls back to full history
SINGLE_MIN_HISTORY=252       # require >= ~1y of data
SINGLE_Z=2.0                 # flag when |z| >= this
SINGLE_MIN_PCT=10            # and % deviation from average >= this

# --- Pair-trade thresholds (from q_pairs.json) ---
PAIR_Z=2.0                   # flag when |z| of current deviation >= this ...
PAIR_DEV_PCT=15              # ... OR absolute deviation from avg ratio >= this %
PAIR_IC_MIN=0.30            # only pairs with historical mean-reversion IC >= this
PAIR_HIT_MIN=60             # ... and quarterly hit rate >= this %
PAIR_MIN_NQ=6              # ... and at least this many quarters of history

# --- How many alerts get a chart ---
TOP_CHARTS_SINGLE=4
TOP_CHARTS_PAIR=4

# --- Data source ---
PE_BASE_URL=https://vhung-1.github.io/PEhistory/
